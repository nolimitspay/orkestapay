# ============================================
# OrkestaPay - Environment Variables
# ============================================
# Copy this file to .env and fill in your keys

PORT=4000
NODE_ENV=development

# ── STRIPE ──────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX
# For multiple Stripe accounts, add numbered versions:
# STRIPE_SECRET_KEY_2=sk_live_YYYYYYYY

# ── SQUARE ──────────────────────────────────
# Get these from: https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=EAAAxxxxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXX
SQUARE_ENVIRONMENT=production
# production | sandbox

# ── TAILORED PAYMENTS ───────────────────────
# Get these from your TailoredPayments dashboard
TAILORED_API_KEY=tp_live_XXXXXXXXXXXXXXXXXXXX
TAILORED_MERCHANT_ID=MERCHANT_XXXXXXXXXXXX
TAILORED_BASE_URL=https://api.tailoredpayments.com/v1

# ── WEBHOOK DELIVERY ────────────────────────
WEBHOOK_SECRET=your_random_secret_for_signing_webhooks

# ── DATABASE (using file DB for simplicity) ──
DB_PATH=./data/orkestapay.json

# ── EMAIL (for cart recovery & notifications) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="OrkestaPay <your@email.com>"

# ── CORS ────────────────────────────────────
FRONTEND_URL=http://localhost:3000
